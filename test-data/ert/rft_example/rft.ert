QUEUE_SYSTEM LOCAL
QUEUE_OPTION LOCAL MAX_RUNNING 4

RANDOM_SEED 11223344

RUNPATH spe1_out/realization-<IENS>/iter-<ITER>

NUM_REALIZATIONS 12

ECLBASE SPE1

OBS_CONFIG obs.txt

GEN_KW FIELD_PROPERTIES field_properties_priors

FORWARD_MODEL TEMPLATE_RENDER( \
    <INPUT_FILES>=parameters.json, \
    <TEMPLATE_FILE>=<CONFIG_PATH>/resources/SPE1.DATA.jinja2, \
    <OUTPUT_FILE>=SPE1.DATA \
)

FORWARD_MODEL FLOW

RFT WELL:PROD DATE:2015-02-01 PROPERTIES:PRESSURE,SWAT,SGAS,SOIL

-- order,utm_x,utm_y,measured_depth,true_vertical_depth,zone,pressure,swat,sgas,soil,valid_zone,is_active,i,j,k,well,time,report_step,observed,error

LOAD_WORKFLOW export_rft_workflow
HOOK_WORKFLOW export_rft_workflow POST_SIMULATION
